{
  "name": "cdse-tsbrowser",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "npm run build && wrangler dev",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "dockview-vue": "^5.1.0",
    "leaflet": "^1.9.4",
    "pinia": "^2.1.7",
    "uplot": "^1.6.32",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.0",
    "wrangler": "^4.78.0"
  }
}
